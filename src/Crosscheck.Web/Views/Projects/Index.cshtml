@using Crosscheck.Application.Projects
@using Crosscheck.Domain.Enums
@model IReadOnlyList<ProjectSummary>
@{
    ViewData["Title"] = "Projects";

    static string StatusBadge(ProjectStatus status) => status switch
    {
        ProjectStatus.Active => "text-bg-success",
        ProjectStatus.OnHold => "text-bg-warning",
        ProjectStatus.Draft => "text-bg-secondary",
        ProjectStatus.Closed => "text-bg-dark",
        _ => "text-bg-light",
    };

    static string StatusLabel(ProjectStatus status) =>
        status == ProjectStatus.OnHold ? "On hold" : status.ToString();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Projects</h1>
    <a class="btn btn-primary" asp-action="Create">New project</a>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Client</th>
            <th>Project manager</th>
            <th>Dates</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var p = item.Project;
            <tr>
                <td><code>@p.Code</code></td>
                <td>@p.Name</td>
                <td>@item.ClientName</td>
                <td>@item.ProjectManagerName</td>
                <td class="text-nowrap">
                    @(p.StartDate?.ToString("yyyy-MM-dd") ?? "—")
                    @if (p.EndDate is not null)
                    {
                        <text>→ @p.EndDate?.ToString("yyyy-MM-dd")</text>
                    }
                </td>
                <td><span class="badge @StatusBadge(p.Status)">@StatusLabel(p.Status)</span></td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Dashboard" asp-route-id="@p.Id" title="Dashboard" aria-label="Dashboard"><i class="bi bi-speedometer2"></i></a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.Id" title="Manage" aria-label="Manage"><i class="bi bi-gear"></i></a>
                    @if (!item.HasTimeEntries)
                    {
                        <form class="d-inline" asp-action="Delete" asp-route-id="@p.Id" method="post"
                              onsubmit="return confirm('Delete @Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode($"{p.Code} — {p.Name}"))? No time has been logged, so the project and its setup (rates, team, budget, modules) will be removed permanently.');">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" aria-label="Delete"><i class="bi bi-trash"></i></button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
