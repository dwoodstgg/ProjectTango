@using Crosscheck.Domain.Enums
@model ProjectFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="mb-3">
    <label asp-for="ClientId" class="form-label"></label>
    <select asp-for="ClientId" asp-items="Model.ClientOptions" class="form-select">
        <option value="">— select client —</option>
    </select>
    <span asp-validation-for="ClientId" class="text-danger"></span>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label asp-for="Code" class="form-label"></label>
        <span class="text-danger" aria-hidden="true">*</span>
        <input asp-for="Code" class="form-control text-uppercase" placeholder="GEO-014" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
</div>

<div class="mb-3">
    <label asp-for="ProjectManagerId" class="form-label"></label>
    <select asp-for="ProjectManagerId" asp-items="Model.ManagerOptions" class="form-select">
        <option value="">— select project manager —</option>
    </select>
    <span asp-validation-for="ProjectManagerId" class="text-danger"></span>
</div>

@* The Edit page hosts project type + dates in the Budget card of the same form instead. *@
@if (ViewData["TypeAndDatesInBudgetCard"] is not true)
{
    <partial name="_TypeAndDates" model="Model" />
}

<fieldset class="form-section" id="billing-fieldset">
    <legend>Billing (overrides the client)</legend>
    <p class="text-muted small mb-3">
        Leave any field blank to use the client's default. Set them here when this project bills to a
        different department or contact.
    </p>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="BillingContactName" class="form-label"></label>
            <input asp-for="BillingContactName" class="form-control" placeholder="Inherit from client" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="BillingContactEmail" class="form-label"></label>
            <input asp-for="BillingContactEmail" class="form-control" placeholder="Inherit from client" />
            <span asp-validation-for="BillingContactEmail" class="text-danger"></span>
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="PaymentTermsDays" class="form-label"></label>
        <div class="input-group" style="max-width: 12rem">
            <input asp-for="PaymentTermsDays" class="form-control" placeholder="Client" />
            <span class="input-group-text">days</span>
        </div>
        <span asp-validation-for="PaymentTermsDays" class="text-danger"></span>
    </div>
    <div class="mb-2"><input asp-for="AddressLine1" class="form-control" placeholder="Address line 1 (inherit from client if blank)" /></div>
    <div class="mb-2"><input asp-for="AddressLine2" class="form-control" placeholder="Address line 2" /></div>
    <div class="row g-2">
        <div class="col-md-5"><input asp-for="City" class="form-control" placeholder="City" /></div>
        <div class="col-md-3"><input asp-for="State" class="form-control" placeholder="State" /></div>
        <div class="col-md-4"><input asp-for="PostalCode" class="form-control" placeholder="ZIP" /></div>
    </div>
</fieldset>

<script>
    // An internal project is never billed and has no timeframe, so the dates and the billing
    // overrides don't apply — hide them when Internal is selected (inputs disabled so they
    // don't post). DOMContentLoaded because on the Edit page the type select renders after
    // this partial, inside the Budget card.
    document.addEventListener('DOMContentLoaded', function () {
        const type = document.getElementById('ProjectType');
        if (!type) return;
        const sections = [
            document.getElementById('project-dates-row'),
            document.getElementById('billing-fieldset'),
        ];
        function sync() {
            const internal = type.value === 'Internal';
            sections.forEach(el => {
                if (!el) return;
                el.classList.toggle('d-none', internal);
                el.querySelectorAll('input').forEach(i => i.disabled = internal);
            });
        }
        type.addEventListener('change', sync);
        sync();
    });
</script>
