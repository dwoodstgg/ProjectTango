@using ProjectTango.Domain.Entities
@model ClientFormViewModel
@{
    var client = (Client)ViewBag.Client;
    ViewData["Title"] = $"Edit {client.Name}";
}

<div class="form-page">
    <form asp-action="Edit" asp-route-id="@client.Id">
        <div class="card shadow-sm form-card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h1>Edit @client.Name</h1>
                @if (client.IsInternal)
                {
                    <span class="badge text-bg-info" title="Internal client — never invoiced">internal</span>
                }
            </div>
            <div class="card-body">
                <partial name="_Form" model="Model" />
            </div>
            <div class="card-footer d-flex gap-2 justify-content-end">
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                <button type="submit" class="btn btn-primary">Save changes</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
