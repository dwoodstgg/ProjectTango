@using ProjectTango.Domain.Entities
@model IReadOnlyList<Client>
@{
    ViewData["Title"] = "Clients";
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Clients</h1>
    <a class="btn btn-primary" asp-action="Create">New client</a>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Billing contact</th>
            <th>Terms</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var client in Model)
        {
            <tr class="@(client.IsActive ? null : "table-secondary text-muted")">
                <td>
                    @client.Name
                    @if (client.IsInternal)
                    {
                        <span class="badge text-bg-info ms-1" title="Internal client — never invoiced">internal</span>
                    }
                </td>
                <td>
                    @client.BillingContactName
                    @if (client.BillingContactEmail is not null)
                    {
                        <span class="text-muted">@client.BillingContactEmail</span>
                    }
                </td>
                <td>@(client.PaymentTermsDays == 0 ? "—" : $"Net-{client.PaymentTermsDays}")</td>
                <td>
                    <span class="badge @(client.IsActive ? "text-bg-success" : "text-bg-secondary")">
                        @(client.IsActive ? "Active" : "Inactive")
                    </span>
                </td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@client.Id">Edit</a>
                    <form asp-action="SetActive" asp-route-id="@client.Id" method="post" class="d-inline">
                        <input type="hidden" name="isActive" value="@((!client.IsActive).ToString())" />
                        <button type="submit" class="btn btn-sm @(client.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                            @(client.IsActive ? "Deactivate" : "Reactivate")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
