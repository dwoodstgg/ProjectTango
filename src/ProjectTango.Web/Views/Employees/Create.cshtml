@using ProjectTango.Domain.Enums
@model CreateEmployeeViewModel
@{
    ViewData["Title"] = "New Employee";
}

<div class="form-page">
    <form asp-action="Create">
        <div class="card shadow-sm form-card">
            <div class="card-header">
                <h1>New employee</h1>
                <p class="form-subtitle">
                    Creates the record ahead of sign-in — it links to their Entra identity
                    automatically the first time they sign in with this email. New employees
                    have no roles until granted.
                </p>
            </div>
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="name@thegeospatialgroup.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DisplayName" class="form-label"></label>
                    <input asp-for="DisplayName" class="form-control" />
                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                </div>

                <div class="mb-1">
                    <label asp-for="EmploymentType" class="form-label"></label>
                    <select asp-for="EmploymentType" class="form-select" style="max-width: 20rem">
                        <option value="@EmploymentType.Employee">Employee (W-2)</option>
                        <option value="@EmploymentType.Subcontractor">Subcontractor (1099)</option>
                    </select>
                </div>
            </div>
            <div class="card-footer d-flex gap-2 justify-content-end">
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                <button type="submit" class="btn btn-primary">Create employee</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
