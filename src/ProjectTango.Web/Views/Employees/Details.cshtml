@using ProjectTango.Domain.Enums
@model EmployeeDetailsViewModel
@{
    var e = Model.Summary.Employee;
    ViewData["Title"] = e.DisplayName;
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@e.DisplayName</h1>
    <form asp-action="SetActive" asp-route-id="@e.Id" method="post">
        <input type="hidden" name="isActive" value="@((!e.IsActive).ToString())" />
        <button type="submit" class="btn @(e.IsActive ? "btn-outline-danger" : "btn-outline-success")">
            @(e.IsActive ? "Deactivate" : "Reactivate")
        </button>
    </form>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-light fw-semibold">Profile</div>
            <div class="card-body">
                <form asp-action="UpdateProfile" asp-route-id="@e.Id">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Profile.DisplayName" class="form-label"></label>
                        <input asp-for="Profile.DisplayName" class="form-control" />
                        <span asp-validation-for="Profile.DisplayName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Profile.EmploymentType" class="form-label"></label>
                        <select asp-for="Profile.EmploymentType" class="form-select">
                            <option value="@EmploymentType.Employee">Employee (W-2)</option>
                            <option value="@EmploymentType.Subcontractor">Subcontractor (1099)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" value="@e.Email" disabled />
                        <div class="form-text">The tenant email is the Entra sign-in key and can't be changed here.</div>
                    </div>

                    <button type="submit" class="btn btn-primary">Save profile</button>
                </form>

                <hr />
                <dl class="row mb-0">
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(e.IsActive ? "text-bg-success" : "text-bg-secondary")">@(e.IsActive ? "Active" : "Inactive")</span>
                    </dd>
                    <dt class="col-sm-4">Entra ID</dt>
                    <dd class="col-sm-8">
                        @if (e.EntraOid is null)
                        {
                            <span class="badge text-bg-warning">Not linked</span>
                            <span class="text-muted small">links on first sign-in</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success">Linked</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-light fw-semibold">Roles</div>
            <div class="card-body">
                <p class="text-muted small">Role changes take effect at the person's next sign-in.</p>
                <table class="table table-sm align-middle mb-0">
                    <tbody>
                        @foreach (var role in Model.AllRoles)
                        {
                            var has = Model.HeldRoleIds.Contains(role.Id);
                            <tr>
                                <td>
                                    @role.DisplayName
                                    @if (role.IsSystemAdmin)
                                    {
                                        <span class="badge text-bg-danger ms-1">system</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (has)
                                    {
                                        <form asp-action="RevokeRole" asp-route-id="@e.Id" method="post" class="d-inline">
                                            <input type="hidden" name="roleId" value="@role.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Revoke</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="GrantRole" asp-route-id="@e.Id" method="post" class="d-inline">
                                            <input type="hidden" name="roleId" value="@role.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Grant</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a class="btn btn-outline-secondary" asp-action="Index">Back to employees</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
