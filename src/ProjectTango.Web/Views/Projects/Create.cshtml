@model ProjectFormViewModel
@{
    ViewData["Title"] = "New Project";
}

<div class="form-page">
    <form asp-action="Create">
        <div class="card shadow-sm form-card">
            <div class="card-header">
                <h1>New project</h1>
                <p class="form-subtitle">
                    Projects start in <strong>Draft</strong>; activate from the manage page
                    when ready for time entry.
                </p>
            </div>
            <div class="card-body">
                <partial name="_Form" model="Model" />
            </div>
            <div class="card-footer d-flex gap-2 justify-content-end">
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                <button type="submit" class="btn btn-primary">Create project</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
