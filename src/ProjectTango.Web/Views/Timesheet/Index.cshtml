@model TimesheetGridViewModel
@{
    ViewData["Title"] = "Timesheet";
    ViewData["ContainerClass"] = "container-fluid px-md-4";
    var today = DateOnly.FromDateTime(DateTime.Today);
    string Fmt(decimal h) => h == 0 ? "" : h.ToString("0.##");
}

<div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-2">
    <div class="d-flex align-items-baseline gap-2">
        <h1 class="mb-0 h3">Timesheet</h1>
        <span class="text-muted">@Model.RangeLabel</span>
    </div>
    <div class="d-flex gap-2">
        <div class="btn-group" role="group" aria-label="Layout">
            <button type="button" class="btn btn-sm btn-primary" id="ts-layout-grid">Grid</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="ts-layout-daily">Daily</button>
        </div>
        <div class="btn-group" role="group" aria-label="View">
            <a class="btn btn-sm @(Model.IsWeek ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Index" asp-route-view="week" asp-route-anchor="@Model.CurrentAnchor.ToString("yyyy-MM-dd")">Week</a>
            <a class="btn btn-sm @(Model.IsWeek ? "btn-outline-secondary" : "btn-primary")"
               asp-action="Index" asp-route-view="month" asp-route-anchor="@Model.CurrentAnchor.ToString("yyyy-MM-dd")">Month</a>
        </div>
    </div>
</div>

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}
<div id="ts-error" class="alert alert-danger d-none" role="alert"></div>

@if (!Model.HasEmployee)
{
    <div class="alert alert-warning">
        Your account isn't linked to an employee record yet. Sign out and back in, or ask an
        administrator to provision your access.
    </div>
    return;
}

@if (Model.Rows.Count == 0)
{
    <div class="alert alert-info">
        You have no project assignments active in @Model.RangeLabel. A project manager assigns you
        to a project before you can log time against it.
    </div>
    return;
}

@Html.AntiForgeryToken()

<p class="text-muted small mb-2">
    Enter hours in quarter-hour steps. Each row bills under its project's assigned role. Billable time
    needs a work description — you'll be prompted for one as you enter hours. Entries save as you go;
    an approved entry is read-only.
</p>

<div class="ts-wrap">
    <table class="ts-grid" id="ts-grid" data-save-url="@Url.Action("SaveHours")">
        <thead>
            <tr>
                <th class="ts-proj">Project</th>
                @foreach (var d in Model.Days)
                {
                    <th class="@(d.IsWeekend ? "ts-weekend" : "") @(d.Date == today ? "ts-today" : "")">@d.Day<span class="ts-dow">@d.WeekdayLabel</span></th>
                }
                <th class="ts-total">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr data-project="@row.ProjectId" data-role="@row.DefaultBillingRoleId">
                    <td class="ts-proj">
                        <div class="ts-proj-label"><span class="ts-proj-client">@row.ClientName</span> – @row.Name</div>
                    </td>
                    @foreach (var d in Model.Days)
                    {
                        row.Cells.TryGetValue(d.DayNumber, out var cell);
                        var status = cell?.Status ?? "open";
                        var editable = !d.Locked && status == "open";
                        <td class="ts-cell @(d.IsWeekend ? "ts-weekend" : "") @(d.Date == today ? "ts-today" : "") @(status == "approved" || status == "invoiced" ? "approved" : "")"
                            data-date="@d.Date.ToString("yyyy-MM-dd")">
                            <input type="text" inputmode="decimal" maxlength="5" autocomplete="off"
                                   class="ts-hours"
                                   value="@(cell is null ? "" : Fmt(cell.Hours))"
                                   title="@(cell?.Notes)"
                                   data-role="@(cell?.BillingRoleId)"
                                   data-notes="@(cell?.Notes)"
                                   @(editable ? "" : "disabled")/>
                            @if (editable)
                            {
                                <button type="button" tabindex="-1"
                                        class="ts-note @(string.IsNullOrWhiteSpace(cell?.Notes) ? "" : "has-note")"
                                        title="@(cell?.Notes)" aria-label="Edit description">@(string.IsNullOrWhiteSpace(cell?.Notes) ? "✎" : "●")</button>
                            }
                        </td>
                    }
                    <td class="ts-total ts-row-total">0</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td class="ts-proj">Daily total</td>
                @foreach (var d in Model.Days)
                {
                    <td class="ts-col-total @(d.IsWeekend ? "ts-weekend" : "") @(d.Date == today ? "ts-today" : "")" data-day="@d.Day">0</td>
                }
                <td class="ts-total" id="ts-grand-total">0</td>
            </tr>
        </tfoot>
    </table>
</div>

<div id="ts-grid-nav" class="d-flex justify-content-center mt-3">
    <div class="btn-group" role="group" aria-label="Navigation">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index"
           asp-route-view="@Model.ViewMode" asp-route-anchor="@Model.PrevAnchor.ToString("yyyy-MM-dd")">&laquo; Prev</a>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index"
           asp-route-view="@Model.ViewMode" asp-route-anchor="@Model.TodayAnchor.ToString("yyyy-MM-dd")">@(Model.IsWeek ? "This week" : "This month")</a>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index"
           asp-route-view="@Model.ViewMode" asp-route-anchor="@Model.NextAnchor.ToString("yyyy-MM-dd")">Next &raquo;</a>
    </div>
</div>

<div id="ts-daily" class="d-none" data-today="@today.ToString("yyyy-MM-dd")"
     data-url="@Url.Action("DailyMonth")" data-layout-url="@Url.Action("SetLayout")"
     data-initial="@Model.InitialLayout">
    <div class="d-flex gap-2 mb-3 align-items-center justify-content-center">
        <select id="ts-daily-month" class="form-select form-select-sm w-auto" aria-label="Month"></select>
        <select id="ts-daily-year" class="form-select form-select-sm w-auto" aria-label="Year"></select>
    </div>
    <div id="ts-daily-cards" class="ts-daily-cards"></div>
</div>

<div id="ts-pop" class="ts-pop d-none" role="dialog" aria-label="Time entry">
    <div class="ts-pop-title" id="ts-pop-title"></div>
    @* Role isn't chosen by the employee — each row bills under its project's assigned billing
       role, carried on the row and sent with the save. *@
    <div class="row g-2 mb-2">
        <div class="col-5">
            <label class="form-label small mb-1">Hours</label>
            <input id="ts-pop-hours" type="number" min="0" max="24" step="0.25" class="form-control form-control-sm" />
        </div>
    </div>
    <label class="form-label small mb-1">Description</label>
    <textarea id="ts-pop-notes" class="form-control form-control-sm" rows="3" placeholder="What was worked on"></textarea>
    <div id="ts-pop-err" class="text-danger small mt-1 d-none"></div>
    <div class="d-flex justify-content-end gap-2 mt-2">
        <button type="button" id="ts-pop-cancel" class="btn btn-sm btn-outline-secondary">Cancel</button>
        <button type="button" id="ts-pop-save" class="btn btn-sm btn-primary">Save</button>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        const grid = document.getElementById('ts-grid');
        const saveUrl = grid.dataset.saveUrl;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const errorBox = document.getElementById('ts-error');

        const num = v => { const n = parseFloat(v); return isNaN(n) ? 0 : n; };

        // Round to 2 decimals and drop trailing zeros. Number.toString never eats a
        // whole number's own zero (10 -> "10"), unlike a trailing-zero regex would.
        const show = (v, zero) => { const n = Math.round(num(v) * 100) / 100; return n ? String(n) : zero; };

        function recalc() {
            const cols = {};
            let grand = 0;
            grid.querySelectorAll('tbody tr').forEach(tr => {
                let rowTotal = 0;
                tr.querySelectorAll('.ts-hours').forEach(inp => {
                    const h = num(inp.value);
                    rowTotal += h;
                    const day = inp.closest('.ts-cell').dataset.date.slice(-2);
                    cols[day] = (cols[day] || 0) + h;
                });
                tr.querySelector('.ts-row-total').textContent = show(rowTotal, '0');
                grand += rowTotal;
            });
            grid.querySelectorAll('.ts-col-total').forEach(td => {
                const day = String(td.dataset.day).padStart(2, '0');
                td.textContent = show(cols[day] || 0, '0');
            });
            document.getElementById('ts-grand-total').textContent = show(grand, '0');
        }

        function flash(cell, cls) {
            cell.classList.remove('saving', 'save-ok', 'save-err');
            if (cls) cell.classList.add(cls);
            if (cls === 'save-ok') setTimeout(() => cell.classList.remove('save-ok'), 700);
        }

        function rowRole(cell) {
            const input = cell.querySelector('.ts-hours');
            return input.dataset.role || cell.closest('tr').dataset.role;
        }

        const esc = s => String(s).replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

        // Posts one entry. Returns the parsed response; callers decide how to react (a missing
        // billable description comes back as {ok:false, needsDescription:true}). `target` names
        // what is being saved (a grid cell or a daily-view row) — see the target factories below.
        async function postSave(target, hours, roleId, notes) {
            if (target.flashEl) flash(target.flashEl, 'saving');
            try {
                const res = await fetch(saveUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
                    body: new URLSearchParams({
                        projectId: target.projectId, date: target.date,
                        hours, billingRoleId: roleId, notes: notes || ''
                    })
                });
                const data = await res.json();
                if (data.ok) { errorBox.classList.add('d-none'); if (target.flashEl) flash(target.flashEl, data.cleared ? null : 'save-ok'); }
                else if (!data.needsDescription) { errorBox.textContent = data.error || 'Could not save entry.'; errorBox.classList.remove('d-none'); if (target.flashEl) flash(target.flashEl, 'save-err'); }
                return data;
            } catch {
                errorBox.textContent = 'Could not reach the server. Try again.';
                errorBox.classList.remove('d-none');
                if (target.flashEl) flash(target.flashEl, 'save-err');
                return { ok: false };
            }
        }

        // Reflects a saved entry back into a grid cell: hours value, stored notes, and the note
        // indicator (● has description, ✎ none).
        function applySavedGrid(cell, data) {
            const input = cell.querySelector('.ts-hours');
            input.value = data.cleared ? '' : show(data.hours, '');
            input.dataset.prev = input.value;
            input.dataset.notes = data.cleared ? '' : (data.notes || '');
            input.title = input.dataset.notes;
            const note = cell.querySelector('.ts-note');
            if (note) {
                const has = !!input.dataset.notes;
                note.classList.toggle('has-note', has);
                note.textContent = has ? '●' : '✎';
                note.title = input.dataset.notes;
            }
            recalc();
        }

        // A grid cell as a save target for the popover/save flow.
        function gridTarget(cell) {
            const input = cell.querySelector('.ts-hours');
            const tr = cell.closest('tr');
            return {
                projectId: tr.dataset.project, date: cell.dataset.date, roleId: rowRole(cell),
                label: tr.querySelector('.ts-proj-label').textContent.trim(),
                hours: input.value, notes: input.dataset.notes || '', flashEl: cell,
                applySaved: data => applySavedGrid(cell, data),
                revert: () => { input.value = input.dataset.prev || ''; recalc(); },
            };
        }

        // ---- Description popover -------------------------------------------------
        const pop = document.getElementById('ts-pop');
        const popTitle = document.getElementById('ts-pop-title');
        const popHours = document.getElementById('ts-pop-hours');
        const popNotes = document.getElementById('ts-pop-notes');
        const popErr = document.getElementById('ts-pop-err');
        let popTarget = null;

        function openPop(target, anchor, prefillHours, focusHours) {
            popTarget = target;
            popTitle.textContent = target.label + ' · ' + target.date;
            popHours.value = prefillHours != null ? prefillHours : target.hours;
            popNotes.value = target.notes || '';
            popErr.classList.add('d-none');

            const r = (anchor || target.flashEl).getBoundingClientRect();
            pop.classList.remove('d-none');
            const w = pop.offsetWidth, h = pop.offsetHeight;
            let left = window.scrollX + Math.min(r.left, window.innerWidth - w - 12);
            let top = window.scrollY + r.bottom + 4;
            if (r.bottom + h + 8 > window.innerHeight) top = window.scrollY + r.top - h - 4;
            pop.style.left = Math.max(window.scrollX + 8, left) + 'px';
            pop.style.top = Math.max(window.scrollY + 8, top) + 'px';
            if (focusHours) { popHours.focus(); popHours.select(); }
            else popNotes.focus();
        }

        function closePop(revert) {
            if (popTarget && revert && popTarget.revert) popTarget.revert();
            pop.classList.add('d-none');
            popTarget = null;
        }

        document.getElementById('ts-pop-cancel').addEventListener('click', () => closePop(true));

        document.getElementById('ts-pop-save').addEventListener('click', async () => {
            if (!popTarget) return;
            const t = popTarget;
            const data = await postSave(t, num(popHours.value), t.roleId, popNotes.value);
            if (data.ok) { t.applySaved(data); closePop(false); }
            else if (data.needsDescription) { popErr.textContent = data.error; popErr.classList.remove('d-none'); popNotes.focus(); }
            else { closePop(true); }
        });

        document.addEventListener('keydown', e => { if (e.key === 'Escape' && !pop.classList.contains('d-none')) closePop(true); });
        document.addEventListener('mousedown', e => {
            if (!pop.classList.contains('d-none') && !pop.contains(e.target) && !e.target.classList.contains('ts-note')) closePop(true);
        });

        grid.querySelectorAll('.ts-note').forEach(btn =>
            btn.addEventListener('click', () => openPop(gridTarget(btn.closest('.ts-cell')))));

        // ---- Inline hours entry --------------------------------------------------
        grid.querySelectorAll('.ts-hours').forEach(input => {
            input.dataset.prev = input.value;
            // Select the contents on focus so tabbing/arrowing into a cell lets you type over
            // whatever's there — no mouse needed to replace a value.
            input.addEventListener('focus', () => input.select());
            // Keep the field numeric (type="text" gives us caret info for arrow-key nav, so we
            // police the characters ourselves): digits and a single decimal point.
            input.addEventListener('input', () => {
                const clean = input.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');
                if (clean !== input.value) input.value = clean;
            });
            input.addEventListener('change', async () => {
                if (input.value === input.dataset.prev) return;
                const cell = input.closest('.ts-cell');
                const target = gridTarget(cell);
                const hours = num(input.value);
                const data = await postSave(target, hours, target.roleId, input.dataset.notes);
                if (data.ok) target.applySaved(data);
                else if (data.needsDescription) openPop(target, cell, hours);   // collect the required description
                else input.value = input.dataset.prev;                          // other error: revert
            });
        });

        // ---- Spreadsheet keyboard navigation -------------------------------------
        // Tab/Shift+Tab already walk across the day columns. These add Excel-style vertical
        // movement (Enter and ↑/↓) plus edge-aware ←/→, so the whole grid is reachable and
        // editable from the keyboard alone. Every row renders every day, so column indexes line up.
        const navRows = Array.from(grid.querySelectorAll('tbody tr'));
        const rowInputs = tr => Array.from(tr.querySelectorAll('.ts-hours'));

        // Move focus from `from` by (dRow, dCol), skipping disabled (locked/approved) cells and
        // stopping at the grid edges.
        function moveFocus(from, dRow, dCol) {
            const tr = from.closest('tr');
            let r = navRows.indexOf(tr);
            let c = rowInputs(tr).indexOf(from);
            if (r < 0 || c < 0) return;
            for (;;) {
                r += dRow; c += dCol;
                if (r < 0 || r >= navRows.length) return;
                const inputs = rowInputs(navRows[r]);
                if (c < 0 || c >= inputs.length) return;
                if (!inputs[c].disabled) { inputs[c].focus(); return; }  // focus handler selects
            }
        }

        grid.querySelectorAll('.ts-hours').forEach(input => {
            input.addEventListener('keydown', e => {
                if (e.altKey || e.ctrlKey || e.metaKey) return;
                const len = input.value.length;
                const atStart = input.selectionStart === 0 && input.selectionEnd === 0;
                const atEnd = input.selectionStart === len && input.selectionEnd === len;
                switch (e.key) {
                    case 'ArrowUp': e.preventDefault(); moveFocus(input, -1, 0); break;
                    case 'ArrowDown': e.preventDefault(); moveFocus(input, 1, 0); break;
                    case 'Enter': e.preventDefault(); moveFocus(input, e.shiftKey ? -1 : 1, 0); break;
                    // Only leave the cell once the caret is already at the matching edge, so ←/→
                    // still move within a multi-character value like "0.25".
                    case 'ArrowLeft': if (atStart) { e.preventDefault(); moveFocus(input, 0, -1); } break;
                    case 'ArrowRight': if (atEnd) { e.preventDefault(); moveFocus(input, 0, 1); } break;
                }
            });
        });

        // ---- Daily view ----------------------------------------------------------
        // A stacked, one-card-per-day view of a full calendar month, chosen with the month/year
        // selectors and fetched on demand. Every assigned project shows for every day so time can
        // be logged on any day; double-clicking a row's hours or description opens the editor.
        const gridWrap = document.querySelector('.ts-wrap');
        const gridNav = document.getElementById('ts-grid-nav');
        const dailyRoot = document.getElementById('ts-daily');
        const dailyCards = document.getElementById('ts-daily-cards');
        const monthSel = document.getElementById('ts-daily-month');
        const yearSel = document.getElementById('ts-daily-year');
        const dailyUrl = dailyRoot.dataset.url;
        const todayIso = dailyRoot.dataset.today;
        const layoutGridBtn = document.getElementById('ts-layout-grid');
        const layoutDailyBtn = document.getElementById('ts-layout-daily');
        const dash = '<span class="text-muted fst-italic">—</span>';

        function dayLabel(iso) {
            return new Date(iso + 'T00:00:00').toLocaleDateString(undefined, { weekday: 'long', month: 'short', day: 'numeric' });
        }

        // Month/year selectors, defaulting to the server's current month.
        (function initSelectors() {
            const [ty, tm] = todayIso.split('-').map(Number);
            for (let m = 1; m <= 12; m++) {
                const o = document.createElement('option');
                o.value = m;
                o.textContent = new Date(2000, m - 1, 1).toLocaleDateString(undefined, { month: 'long' });
                monthSel.appendChild(o);
            }
            for (let y = ty - 3; y <= ty + 1; y++) {
                const o = document.createElement('option');
                o.value = y; o.textContent = y;
                yearSel.appendChild(o);
            }
            monthSel.value = tm; yearSel.value = ty;
        })();

        // A daily-view row as a save target.
        function dailyTarget(tr) {
            return {
                projectId: tr.dataset.project, date: tr.dataset.date, roleId: tr.dataset.role,
                label: tr.dataset.label, hours: tr.dataset.hours || '', notes: tr.dataset.notes || '',
                flashEl: tr, applySaved: data => applySavedDaily(tr, data), revert: () => {},
            };
        }

        function applySavedDaily(tr, data) {
            tr.dataset.hours = data.cleared ? '' : show(data.hours, '');
            tr.dataset.notes = data.cleared ? '' : (data.notes || '');
            const h = num(tr.dataset.hours);
            tr.querySelector('.ts-d-hours').innerHTML = h > 0 ? show(h, '0') : dash;
            tr.querySelector('.ts-d-desc').innerHTML = tr.dataset.notes ? esc(tr.dataset.notes) : dash;
            const card = tr.closest('.ts-day-card');
            let total = 0;
            card.querySelectorAll('tbody tr').forEach(r => total += num(r.dataset.hours));
            card.querySelector('.ts-day-total').textContent = show(total, '0') + ' h';
        }

        function renderDaily(data) {
            const frag = document.createDocumentFragment();
            data.days.forEach(day => {
                let total = 0;
                const lines = data.projects.map(p => {
                    const cell = p.cells[day.date];
                    const h = cell ? num(cell.hours) : 0;
                    total += h;
                    const notes = cell ? (cell.notes || '') : '';
                    const status = cell ? cell.status : 'open';
                    const editable = !day.locked && status === 'open';
                    return '<tr data-project="' + p.id + '" data-date="' + day.date + '" data-role="' + (p.roleId || '')
                        + '" data-hours="' + (h > 0 ? show(h, '') : '') + '" data-notes="' + esc(notes)
                        + '" data-label="' + esc(p.label) + '"' + (editable ? '' : ' class="ts-d-locked"') + '>'
                        + '<td class="ts-d-proj">' + esc(p.label) + '</td>'
                        + '<td class="ts-d-hours text-end">' + (h > 0 ? show(h, '0') : dash) + '</td>'
                        + '<td class="ts-d-desc">' + (notes ? esc(notes) : dash) + '</td></tr>';
                });
                const body = data.projects.length
                    ? '<div class="table-responsive"><table class="table table-sm ts-day-table mb-0">'
                        + '<thead><tr><th>Project</th><th class="text-end ts-day-hcol">Hours</th><th>Description</th></tr></thead>'
                        + '<tbody>' + lines.join('') + '</tbody></table></div>'
                    : '<div class="card-body text-muted small">No assigned projects.</div>';
                const weekday = new Date(day.date + 'T00:00:00').getDay();  // 0 Sun … 6 Sat
                const isWeekend = weekday === 0 || weekday === 6;
                const card = document.createElement('div');
                card.className = 'card ts-day-card'
                    + (isWeekend ? ' ts-day-weekend' : '')
                    + (day.date === todayIso ? ' ts-day-today' : '');
                card.innerHTML = '<div class="card-header d-flex justify-content-between align-items-center">'
                    + '<span class="fw-semibold">' + esc(dayLabel(day.date)) + '</span>'
                    + '<span class="text-muted small ts-day-total">' + show(total, '0') + ' h</span></div>' + body;
                frag.appendChild(card);
            });
            dailyCards.replaceChildren(frag);
            // Bring the current day into view when it's part of the month being shown.
            dailyCards.querySelector('.ts-day-today')?.scrollIntoView({ block: 'center' });
        }

        async function loadDaily() {
            dailyCards.innerHTML = '<div class="text-muted small p-2">Loading…</div>';
            try {
                const res = await fetch(dailyUrl + '?year=' + (+yearSel.value) + '&month=' + (+monthSel.value), { headers: { 'Accept': 'application/json' } });
                renderDaily(await res.json());
            } catch {
                dailyCards.innerHTML = '<div class="alert alert-danger">Could not load the month. Try again.</div>';
            }
        }

        dailyCards.addEventListener('dblclick', e => {
            const td = e.target.closest('.ts-d-hours, .ts-d-desc');
            if (!td) return;
            const tr = td.closest('tr');
            if (tr.classList.contains('ts-d-locked')) return;
            openPop(dailyTarget(tr), td, undefined, true);   // focus the hours field for quick entry
        });

        monthSel.addEventListener('change', loadDaily);
        yearSel.addEventListener('change', loadDaily);

        // Persists the chosen layout server-side so it syncs across the user's devices.
        const layoutUrl = dailyRoot.dataset.layoutUrl;
        async function persistLayout(layout) {
            try {
                await fetch(layoutUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
                    body: new URLSearchParams({ layout })
                });
            } catch { /* preference is best-effort — a failed save just isn't remembered */ }
        }

        function setLayout(daily, persist = true) {
            gridWrap.classList.toggle('d-none', daily);
            gridNav.classList.toggle('d-none', daily);
            dailyRoot.classList.toggle('d-none', !daily);
            layoutDailyBtn.classList.toggle('btn-primary', daily);
            layoutDailyBtn.classList.toggle('btn-outline-secondary', !daily);
            layoutGridBtn.classList.toggle('btn-primary', !daily);
            layoutGridBtn.classList.toggle('btn-outline-secondary', daily);
            if (persist) persistLayout(daily ? 'daily' : 'grid');
            if (daily) loadDaily();
        }

        layoutGridBtn.addEventListener('click', () => setLayout(false));
        layoutDailyBtn.addEventListener('click', () => setLayout(true));

        recalc();

        // Apply the layout the server remembers for this user (grid is the rendered default).
        if (dailyRoot.dataset.initial === 'daily') setLayout(true, false);
    })();
</script>
}
